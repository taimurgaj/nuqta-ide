# Copy to .env.local and fill in

# Railway API URL — when set, "Run" POSTs here instead of using the browser interpreter
# Leave blank to use the TypeScript interpreter (offline/demo mode)
VITE_API_URL=https://api.urdutech.org

# Supabase — for feedback + bug reports stored directly from the browser
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Optional: set to /assets/... if serving the IDE from a sub-path
# VITE_BASE_URL=/
